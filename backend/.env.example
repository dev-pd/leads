# ---- Core ----
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api
CORS_ORIGINS=http://localhost:3000

# ---- Database ----
# Host-run default. docker-compose overrides the host to the `db` service.
DATABASE_URL=postgresql+psycopg://leads:leads@localhost:5432/leads

# ---- Auth (JWT) ----
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440

# Seed attorney account (created/updated by scripts/seed.py on boot)
ATTORNEY_EMAIL=attorney@example.com
ATTORNEY_PASSWORD=changeme123
ATTORNEY_NAME=Default Attorney

# ---- Email (Resend) ----
# Leave RESEND_API_KEY empty to log emails instead of sending (no creds needed).
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
NOTIFY_ATTORNEY_EMAIL=attorney@example.com

# ---- AI resume summary (Anthropic API) ----
# Leave empty to disable. With a key set, each submitted resume is summarized
# into an attorney-facing profile via the Anthropic Messages API.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ---- Storage ----
# local  -> files on disk (LOCAL_STORAGE_DIR)
# s3     -> MinIO / AWS S3 (S3_* vars below)
STORAGE_BACKEND=s3
LOCAL_STORAGE_DIR=/data/resumes
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=resumes
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1

# ---- Uploads ----
MAX_UPLOAD_MB=10
ALLOWED_RESUME_TYPES=application/pdf
